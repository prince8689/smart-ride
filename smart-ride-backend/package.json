{
  "name": "smart-ride-backend",
  "version": "1.0.0",
  "description": "Smart Ride - Monthly Pickup & Drop Subscription Platform Backend",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node src/config/initDb.js",
    "seed": "node src/config/seed.js",
    "migrate": "psql $DATABASE_URL -f src/config/schema.sql",
    "migrate:indexes": "psql $DATABASE_URL -f src/config/migrations/002_performance_indexes.sql",
    "migrate:safe": "node src/config/runMigrations.js",
    "demo:seed": "node src/config/seed.js --demo",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "smart-ride",
    "subscription",
    "pickup-drop",
    "transportation"
  ],
  "author": "",
  "license": "ISC"
}
