# =============================================
# Smart Ride Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---------- Server ----------
PORT=5000
NODE_ENV=development

# ---------- Database ----------
# Local PostgreSQL: postgresql://username:password@localhost:5432/smart_ride_db
# Railway PostgreSQL: use the connection string provided by Railway
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/smart_ride_db

# ---------- JWT Authentication ----------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ---------- Razorpay Payment Gateway ----------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Razorpay Webhook Secret (from Razorpay dashboard > Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ---------- Email (Nodemailer) ----------
# Use Gmail App Password or SMTP credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ---------- Frontend URL (CORS) ----------
FRONTEND_URL=http://localhost:3000

# ---------- Map Provider ----------
# Options: 'google' or 'mappls'
MAP_PROVIDER=google

# ---------- Google Maps ----------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---------- MapmyIndia (Mappls) ----------
MAPPLS_API_KEY=your_mappls_api_key
MAPPLS_CLIENT_ID=your_mappls_client_id
MAPPLS_CLIENT_SECRET=your_mappls_client_secret
